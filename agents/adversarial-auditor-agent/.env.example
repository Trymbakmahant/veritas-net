# Copy to .env in this folder, or export before `npm run dev`.

# HTTP port for this agent (default 8803)
PORT=8803

# ---------------------------------------------------------------------------
# 0G Compute (optional). If these are missing, the critic uses local heuristics
# + a mock receipt (mock-zgc://...).
# ---------------------------------------------------------------------------

# Recommended: 0G Compute Router / proxy endpoint generated by the 0G UI.
ZG_COMPUTE_API_URL=https://compute-network-.../v1/proxy/chat/completions
ZG_COMPUTE_API_KEY=app-sk-...
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Direct provider mode (fallback): on-chain 0G Compute provider address.
ZG_COMPUTE_PROVIDER=

# Same Galileo RPC you use for the backend (e.g. https://evmrpc-testnet.0g.ai).
ZG_RPC_URL=

# Funded wallet private key on Galileo (must match what the broker expects).
# Same key as backend COORDINATOR_PRIVATE_KEY is typical.
COORDINATOR_PRIVATE_KEY=0x...
