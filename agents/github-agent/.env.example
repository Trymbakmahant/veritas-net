# Copy to .env in this folder, or export before `npm run dev`.
# Defaults work for local demo; override only what you need.

# HTTP port for this agent (default 8801)
PORT=8801

# Optional: GitHub fine-grained or classic PAT for higher API rate limits.
# The coordinator can send Authorization on your behalf; if unset here,
# pass token from backend GITHUB_TOKEN when the coordinator calls /verify.

GITHUB_TOKEN=
