# Single deployable agent service for all verifier capabilities and auditor.
PORT=8810

# Optional GitHub token for higher API limits.
GITHUB_TOKEN=

# DEXScreener base URL.
DEXSCREENER_API_BASE=https://api.dexscreener.com

# 0G Compute Router / proxy endpoint generated by the 0G UI.
ZG_COMPUTE_API_URL=https://compute-network-.../v1/proxy/chat/completions
ZG_COMPUTE_API_KEY=app-sk-...
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Optional direct 0G Compute fallback.
ZG_COMPUTE_PROVIDER=
ZG_RPC_URL=
COORDINATOR_PRIVATE_KEY=0x...

# Optional AXL runtime. Leave unset for direct HTTP mode.
AXL_HTTP_URL=
AXL_PEER_ID=master-agent
