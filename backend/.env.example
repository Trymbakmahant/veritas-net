PORT=8787

# ----------------------------------------------------------------------------
# Chain (0G Galileo testnet)
# ----------------------------------------------------------------------------
RPC_URL=https://evmrpc-testnet.0g.ai
COORDINATOR_PRIVATE_KEY=0x...

# Filled by `cd contract && npm run deploy:zg` (see deployments/<network>.json)
VERITAS_ORACLE_ADDRESS=0x...
ORACLE_INFT_ADDRESS=0x...
ROYALTY_ROUTER_ADDRESS=0x...

# Optional fixed mapping when running iNFT in mock mode (no chain reads).
# Format:  ORACLE_TOKEN_IDS=github:1,snapshot:2,auditor:3
ORACLE_TOKEN_IDS=

# ----------------------------------------------------------------------------
# Local agent endpoints (legacy fallback used when nothing is registered
# on-chain for a capability; the dynamic registry is preferred).
# ----------------------------------------------------------------------------
GITHUB_AGENT_URL=http://localhost:8801
SNAPSHOT_AGENT_URL=http://localhost:8802
AUDITOR_AGENT_URL=http://localhost:8803
GITHUB_TOKEN=

# Dynamic-registry env fallback (used when an on-chain oracle has a
# placeholder bundleUri so the manifest can't be fetched from 0G).
# Format: AGENT_ENDPOINTS=name=url,name=url
#         AGENT_CAPABILITIES=name=cap1|cap2,name=cap1
AGENT_ENDPOINTS=github=http://localhost:8801,snapshot=http://localhost:8802,auditor=http://localhost:8803
AGENT_CAPABILITIES=github=github_pr_merged_before,snapshot=snapshot_proposal_passed,auditor=critic

# Private key used by `scripts/register-agent.ts` (defaults to
# COORDINATOR_PRIVATE_KEY when unset). Anyone can register their own agent
# by funding their own key on 0G Galileo.
REGISTER_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Consensus thresholds
# ----------------------------------------------------------------------------
RESOLVABILITY_THRESHOLD=0.5
AGREEMENT_THRESHOLD=0.67
AUTO_RESOLVE=true

# ----------------------------------------------------------------------------
# 0G Storage
# - Blob proofs: ZG_RPC_URL + ZG_INDEXER_URL + ZG_PRIVATE_KEY (or COORDINATOR_PRIVATE_KEY).
#   uploads via indexer; check root on https://storagescan-galileo.0g.ai — no stream id required.
# - On-chain KV: also set ZG_KV_NODE_URL, ZG_FLOW_CONTRACT, ZG_STREAM_ID (must have WRITE on stream).
# Leave all ZG_* blank for in-memory mock.
# ----------------------------------------------------------------------------
ZG_RPC_URL=
ZG_INDEXER_URL=
ZG_KV_NODE_URL=
ZG_FLOW_CONTRACT=
ZG_STREAM_ID=
ZG_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# 0G Compute (verifiable inference).  Leave blank to use deterministic MOCK.
# ----------------------------------------------------------------------------
ZG_COMPUTE_PROVIDER=

# ----------------------------------------------------------------------------
# Gensyn AXL (P2P mesh).  Leave blank to use in-process pub/sub MOCK.
# ----------------------------------------------------------------------------
AXL_HTTP_URL=
AXL_PEER_ID=local-coordinator
